@model Team
@{
    ViewData["Title"] = $"{Model.TeamName} - Team Details";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Simulation")">Dashboard</a></li>
                    <li class="breadcrumb-item active">@Model.TeamName</li>
                </ol>
            </nav>
        </div>
    </div>

    <!-- Team Header -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4" style="background: linear-gradient(135deg, rgb(@Model.TeamColor1R, @Model.TeamColor1G, @Model.TeamColor1B) 0%, rgb(@Model.TeamColor2R, @Model.TeamColor2G, @Model.TeamColor2B) 100%);">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h1 class="text-white mb-0">@Model.TeamName</h1>
                            <p class="text-white-50 mb-0">Founded in @Model.FoundationYear</p>
                        </div>
                        <div class="col-md-4 text-md-end text-white">
                            <div class="fs-3 fw-bold">@Model.OverallRating</div>
                            <small>Overall Rating</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <ul class="nav nav-tabs mb-4" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" id="roster-tab" data-bs-toggle="tab" href="#roster" role="tab">
                <i class="fa fa-users"></i> Roster
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" id="stats-tab" data-bs-toggle="tab" href="#stats" role="tab">
                <i class="fa fa-bar-chart"></i> Statistics
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" id="matches-tab" data-bs-toggle="tab" href="#matches" role="tab">
                <i class="fa fa-calendar"></i> Matches
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" id="info-tab" data-bs-toggle="tab" href="#info" role="tab">
                <i class="fa fa-building"></i> Info
            </a>
        </li>
    </ul>

    <div class="tab-content">
        <!-- Roster Tab -->
        <div class="tab-pane fade show active" id="roster" role="tabpanel">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Squad - @Model.Players.Count Players</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Jersey</th>
                                    <th>Player</th>
                                    <th>Pos</th>
                                    <th>Age</th>
                                    <th>Rating</th>
                                    <th>Pace</th>
                                    <th>Shooting</th>
                                    <th>Passing</th>
                                    <th>Dribbling</th>
                                    <th>Defense</th>
                                    <th>Physical</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var player in Model.Players.OrderBy(p => p.JerseyNumber))
                                {
                                    <tr class="player-row" style="cursor: pointer;" onclick="location.href='@Url.Action("PlayerDetails", "Simulation", new { playerId = player.PlayerId })'">
                                        <td><span class="badge bg-secondary fs-6">@player.JerseyNumber</span></td>
                                        <td>
                                            <strong>@player.FullName</strong>
                                        </td>
                                        <td>
                                            @{
                                                var positionNames = new Dictionary<int, string>
                                                {
                                                    { 0, "GK" }, { 1, "CB" }, { 2, "LB" }, { 3, "RB" }, { 4, "LWB" }, { 5, "RWB" },
                                                    { 6, "CM" }, { 7, "CAM" }, { 8, "RM" }, { 9, "LM" }, { 10, "CDM" }, { 11, "ST" },
                                                    { 12, "CF" }, { 13, "LW" }, { 14, "RW" }, { 15, "LF" }, { 16, "RF" }
                                                };
                                                var pos = positionNames.GetValueOrDefault(player.PreferredPosition1, "N/A");
                                            }
                                            <span class="badge bg-info">@pos</span>
                                        </td>
                                        <td>@(DateTime.Now.Year - (player.Age > 0 ? DateTime.Now.Year - player.Age : 0))</td>
                                        <td><span class="badge bg-primary">@player.OverallRating</span></td>
                                        <td>@player.SprintSpeed</td>
                                        <td>@player.ShotPower</td>
                                        <td>@player.ShortPassing</td>
                                        <td>@player.Dribbling_Detailed</td>
                                        <td>@player.StandingTackle</td>
                                        <td>@player.Strength</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats Tab -->
        <div class="tab-pane fade" id="stats" role="tabpanel">
            <div class="row">
                <div class="col-md-6">
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">Team Ratings</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <strong>Overall</strong>
                                    <span class="badge bg-primary">@Model.OverallRating</span>
                                </div>
                                <div class="progress">
                                    <div class="progress-bar bg-primary" style="width: @(Model.OverallRating)%"></div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <strong>Attack</strong>
                                    <span class="badge bg-success">@Model.AttackRating</span>
                                </div>
                                <div class="progress">
                                    <div class="progress-bar bg-success" style="width: @(Model.AttackRating)%"></div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <strong>Midfield</strong>
                                    <span class="badge bg-info">@Model.MidfieldRating</span>
                                </div>
                                <div class="progress">
                                    <div class="progress-bar bg-info" style="width: @(Model.MidfieldRating)%"></div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <strong>Defense</strong>
                                    <span class="badge bg-danger">@Model.DefenseRating</span>
                                </div>
                                <div class="progress">
                                    <div class="progress-bar bg-danger" style="width: @(Model.DefenseRating)%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-secondary text-white">
                            <h5 class="mb-0">Season Statistics</h5>
                        </div>
                        <div class="card-body">
                            <div class="row text-center">
                                <div class="col-md-6 mb-3">
                                    <div class="fs-4 fw-bold">@Model.MatchesPlayed</div>
                                    <small class="text-muted">Matches Played</small>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="fs-4 fw-bold text-success">@Model.Wins</div>
                                    <small class="text-muted">Wins</small>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="fs-4 fw-bold text-secondary">@Model.Draws</div>
                                    <small class="text-muted">Draws</small>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="fs-4 fw-bold text-danger">@Model.Losses</div>
                                    <small class="text-muted">Losses</small>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="fs-4 fw-bold">@Model.GoalsFor</div>
                                    <small class="text-muted">Goals For</small>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="fs-4 fw-bold">@Model.GoalsAgainst</div>
                                    <small class="text-muted">Goals Against</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <div class="card shadow-sm">
                        <div class="card-header bg-secondary text-white">
                            <h5 class="mb-0">Achievements</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-4">
                                    <p><strong>League Titles:</strong> <span class="badge bg-gold">@Model.LeagueTitles</span></p>
                                </div>
                                <div class="col-md-4">
                                    <p><strong>Domestic Cups:</strong> <span class="badge bg-warning">@Model.DomesticCups</span></p>
                                </div>
                                <div class="col-md-4">
                                    <p><strong>UEFA CL Wins:</strong> <span class="badge bg-primary">@Model.UEFACLWins</span></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Matches Tab -->
        <div class="tab-pane fade" id="matches" role="tabpanel">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Recent Matches</h5>
                </div>
                <div class="card-body p-0">
                    @if (ViewBag.TeamMatches != null && ((List<Match>)ViewBag.TeamMatches).Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-striped mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Matchday</th>
                                        <th>Opponent</th>
                                        <th>Result</th>
                                        <th>Score</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var match in ((List<Match>)ViewBag.TeamMatches).OrderByDescending(m => m.MatchDay))
                                    {
                                        var isHome = match.HomeTeamId == Model.TeamId;
                                        var opponent = isHome ? match.AwayTeam?.TeamName : match.HomeTeam?.TeamName;
                                        var result = isHome ? 
                                            (match.HomeGoals > match.AwayGoals ? "Win" : (match.HomeGoals < match.AwayGoals ? "Loss" : "Draw")) :
                                            (match.AwayGoals > match.HomeGoals ? "Win" : (match.AwayGoals < match.HomeGoals ? "Loss" : "Draw"));
                                        var resultBadgeClass = result == "Win" ? "bg-success" : (result == "Loss" ? "bg-danger" : "bg-secondary");
                                        var score = isHome ? $"{match.HomeGoals} - {match.AwayGoals}" : $"{match.AwayGoals} - {match.HomeGoals}";

                                        <tr>
                                            <td>@match.MatchDay</td>
                                            <td>@(isHome ? "vs" : "at") <strong>@opponent</strong></td>
                                            <td><span class="badge @resultBadgeClass">@result</span></td>
                                            <td><strong>@score</strong></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted">
                            No matches played yet.
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Info Tab -->
        <div class="tab-pane fade" id="info" role="tabpanel">
            <div class="row">
                <div class="col-md-6">
                    <div class="card shadow-sm">
                        <div class="card-header bg-secondary text-white">
                            <h5 class="mb-0">Club Information</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>Stadium:</strong> <span class="text-primary">@Model.StadiumName</span></p>
                            <p><strong>Capacity:</strong> <span class="text-primary">@Model.TeamStadiumCapacity.ToString("N0")</span></p>
                            <p><strong>Founded:</strong> <span class="text-primary">@Model.FoundationYear</span></p>
                            <p><strong>Domestic Prestige:</strong> <span class="badge bg-warning">@Model.DomesticPrestige</span></p>
                            <p><strong>International Prestige:</strong> <span class="badge bg-info">@Model.InternationalPrestige</span></p>
                            <p><strong>Popularity:</strong> <span class="badge bg-danger">@Model.Popularity</span></p>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card shadow-sm">
                        <div class="card-header bg-secondary text-white">
                            <h5 class="mb-0">Financial</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>Club Worth:</strong> <span class="text-primary">$@Model.ClubWorth.ToString("N0")</span></p>
                            <p><strong>Profitability:</strong> <span class="text-primary">@Model.Profitability</span></p>
                            <p><strong>Youth Development:</strong> <span class="text-primary">Active</span></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a href="@Url.Action("Index", "Simulation")" class="btn btn-secondary">
            <i class="fa fa-arrow-left"></i> Back to Dashboard
        </a>
    </div>
</div>

<style>
    .player-row:hover {
        background-color: #f8f9fa;
        transition: background-color 0.2s;
    }

    .bg-gold {
        background-color: #FFD700 !important;
        color: #333 !important;
    }
</style>
