@model List<FootballSimulator.Models.League>
@{
    ViewData["Title"] = "Football Simulator";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 mb-3">⚽ Football Simulator</h1>
        <p class="lead text-muted">Simulate realistic football matches with EA Sports FC 26 data</p>
    </div>

    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="alert alert-info mb-4" role="alert">
                <strong>Welcome!</strong> Select a league below to view teams, standings, and start a season simulation.
            </div>

            @if (Model == null || Model.Count == 0)
            {
                <div class="alert alert-warning" role="alert">
                    <strong>No leagues found.</strong> Redirecting to league selection...
                </div>
                <meta http-equiv="refresh" content="2; url=@Url.Action("Index", "League")" />
            }
            else
            {
                <div class="row">
                    @foreach (var league in Model.Where(l => l.Teams.Count > 0).OrderBy(l => l.LeagueName))
                    {
                        <div class="col-md-6 mb-4">
                            <div class="card league-quick-card h-100 shadow-sm">
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title mb-2">@league.LeagueName</h5>
                                    <p class="card-text text-muted small mb-3">
                                        <strong>@league.Teams.Count</strong> Teams • <strong>@league.GetTotalMatchdays()</strong> Matchdays
                                    </p>
                                    <div class="mt-auto">
                                        <a href="@Url.Action("Index", "League")" class="btn btn-primary btn-sm w-100 mb-2">
                                            <i class="fas fa-arrow-right"></i> Go to Leagues
                                        </a>
                                        <a href="@Url.Action("StartSeason", "Simulation", new { leagueId = league.LeagueId })" class="btn btn-success btn-sm w-100">
                                            <i class="fas fa-play"></i> Start Season
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="text-center mt-5">
                    <a href="@Url.Action("Index", "League")" class="btn btn-lg btn-primary">
                        <i class="fas fa-list"></i> View All Leagues
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .league-quick-card {
        transition: transform 0.2s, box-shadow 0.2s;
        border: none;
        border-top: 3px solid #007bff;
    }

    .league-quick-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }

    .display-4 {
        font-weight: 700;
        color: #1a5a1a;
    }
</style>
