@model List<FootballSimulator.Models.League>

@{
    ViewData["Title"] = "Football Leagues";
}

<div class="container mt-5">
    <h1 class="mb-4">Football Leagues</h1>
    <p class="lead text-muted mb-4">Select a league to view teams, standings, and start a season simulation.</p>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-warning" role="alert">
            <strong>No leagues found.</strong> Please check the data configuration.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var league in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card league-card shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@league.LeagueName</h5>
                            <p class="card-text text-muted small">
                                <span class="badge bg-info">@league.Teams.Count Teams</span>
                                <span class="badge bg-secondary">@league.GetTotalMatchdays() Matchdays</span>
                            </p>
                            <hr />
                            <div class="league-teams-preview mb-3">
                                <strong>Teams:</strong>
                                <div class="team-list-small">
                                    @{
                                        var previewTeams = league.Teams.Take(5);
                                    }
                                    @foreach (var team in previewTeams)
                                    {
                                        <small class="d-block text-truncate">• @team.TeamName</small>
                                    }
                                    @if (league.Teams.Count > 5)
                                    {
                                        <small class="d-block text-muted">... and @(league.Teams.Count - 5) more</small>
                                    }
                                </div>
                            </div>
                            <div class="btn-group w-100" role="group">
                                <a href="@Url.Action("Details", new { leagueId = league.LeagueId })" class="btn btn-primary btn-sm">
                                    <i class="fas fa-eye"></i> View
                                </a>
                                <a href="@Url.Action("Standings", new { leagueId = league.LeagueId })" class="btn btn-info btn-sm">
                                    <i class="fas fa-table"></i> Table
                                </a>
                                <a href="@Url.Action("StartSeason", "Simulation", new { leagueId = league.LeagueId })" class="btn btn-success btn-sm">
                                    <i class="fas fa-play"></i> Start
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .league-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .league-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }

    .team-list-small {
        font-size: 0.875rem;
        max-height: 120px;
        overflow-y: auto;
        padding-right: 0.5rem;
    }

    .team-list-small::-webkit-scrollbar {
        width: 6px;
    }

    .team-list-small::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 10px;
    }

    .team-list-small::-webkit-scrollbar-thumb {
        background: #888;
        border-radius: 10px;
    }

    .team-list-small::-webkit-scrollbar-thumb:hover {
        background: #555;
    }

    .btn-group {
        gap: 2px;
    }

    .btn-group .btn {
        flex: 1;
        border-radius: 4px;
        font-size: 0.8rem;
        padding: 0.4rem 0.6rem;
    }
</style>
