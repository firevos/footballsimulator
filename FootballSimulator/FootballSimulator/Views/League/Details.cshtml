@model FootballSimulator.Models.League

@{
    ViewData["Title"] = ViewBag.League?.LeagueName ?? "League Details";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="mb-3">@ViewBag.League?.LeagueName</h1>
            <div class="d-flex gap-2 mb-4">
                <span class="badge bg-primary">@ViewBag.TeamCount Teams</span>
                <span class="badge bg-info">@ViewBag.MatchesPerMatchday Matches per Matchday</span>
                <span class="badge bg-success">@ViewBag.TotalMatchdays Total Matchdays</span>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Current Standings</h5>
                </div>
                <div class="card-body p-0">
                    @if (ViewBag.League?.Teams.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Position</th>
                                        <th>Team</th>
                                        <th class="text-center">MP</th>
                                        <th class="text-center">W</th>
                                        <th class="text-center">D</th>
                                        <th class="text-center">L</th>
                                        <th class="text-center">GF</th>
                                        <th class="text-center">GA</th>
                                        <th class="text-center">GD</th>
                                        <th class="text-center fw-bold">Pts</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var standings = ViewBag.League?.GetStandings();
                                        int position = 1;
                                    }
                                    @foreach (var team in standings ?? new List<FootballSimulator.Models.Team>())
                                    {
                                        <tr>
                                            <td>
                                                <span class="badge bg-secondary">@position</span>
                                            </td>
                                            <td>
                                                <a href="@Url.Action("TeamDetails", "Simulation", new { teamId = team.TeamId, leagueId = ViewBag.League?.LeagueId })" class="text-decoration-none">
                                                    @team.TeamName
                                                </a>
                                            </td>
                                            <td class="text-center">@team.MatchesPlayed</td>
                                            <td class="text-center text-success fw-bold">@team.Wins</td>
                                            <td class="text-center text-info fw-bold">@team.Draws</td>
                                            <td class="text-center text-danger fw-bold">@team.Losses</td>
                                            <td class="text-center">@team.GoalsFor</td>
                                            <td class="text-center">@team.GoalsAgainst</td>
                                            <td class="text-center">@team.GoalDifference</td>
                                            <td class="text-center fw-bold">@team.Points</td>
                                        </tr>
                                        position++;
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">League Information</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <strong>Teams:</strong>
                        <br />
                        <small class="text-muted">@ViewBag.TeamCount total teams</small>
                    </div>
                    <div class="mb-3">
                        <strong>Schedule:</strong>
                        <br />
                        <small class="text-muted">@ViewBag.MatchesPerMatchday matches per matchday</small>
                        <br />
                        <small class="text-muted">@ViewBag.TotalMatchdays matchdays total</small>
                    </div>
                    <div class="mb-3">
                        <strong>Season Format:</strong>
                        <br />
                        <small class="text-muted">Round-robin (each team plays all others twice)</small>
                    </div>
                    <hr />
                    <div class="d-grid gap-2">
                        <a href="@Url.Action("Teams", new { leagueId = ViewBag.League?.LeagueId })" class="btn btn-outline-primary">
                            <i class="fas fa-list"></i> View All Teams
                        </a>
                        <a href="@Url.Action("StartSeason", "Simulation", new { leagueId = ViewBag.League?.LeagueId })" class="btn btn-success">
                            <i class="fas fa-play"></i> Start Season
                        </a>
                        <a href="@Url.Action("Index", "League")" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left"></i> Back to Leagues
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: #f5f5f5;
    }

    .badge {
        font-size: 0.85rem;
        padding: 0.4rem 0.6rem;
    }
</style>
